{
  "manifest_version": 3,
  "name": "EdickExt",
  "version": "1.0.0",
  "description": "Tinkoff investments tracker with terminal integration",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "scripting",
    "storage",
    "activeTab",
    "notifications",
    "alarms",
    "background"
  ],
  "host_permissions": [
    "https://invest-public-api.tinkoff.ru/*",
    "https://api-invest.tinkoff.ru/*",
    "https://*.tinkoff.ru/*",
    "https://*.tbank.ru/*",
    "wss://extension.api.askerovgroup.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.tinkoff.ru/terminal/*",
        "https://*.tbank.ru/terminal/*"
      ],
      "js": [
        "react.production.min.js",
        "react-dom.production.min.js",
        "widgets.iife.js",
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "react.production.min.js",
        "react-dom.production.min.js",
        "widgets.iife.js"
      ],
      "matches": [
        "https://*.tinkoff.ru/*",
        "https://*.tbank.ru/*"
      ]
    }
  ]
}