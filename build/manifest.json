{
  "manifest_version": 3,
  "name": "EdickExt",
  "version": "1.0.0",
  "description": "A simple React app as a Chrome extension",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://invest-public-api.tinkoff.ru/*",
    "https://api-invest.tinkoff.ru/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://invest-public-api.tinkoff.ru https://api-invest.tinkoff.ru"
  }
}